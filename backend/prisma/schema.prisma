generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum AppointmentStatus {
  zarezerwowana
  zrealizowana
  odwołana
}

enum UserRole {
  admin
  patient
  doctor
}

model User {
  id           Int           @id @default(autoincrement())
  firstname    String
  lastname     String
  birth_date   DateTime      @db.Date
  email        String        @unique
  password     String
  role         UserRole
  created_at   DateTime      @default(now())
  verified     Boolean       @default(true)
  doctor       Doctor?
  appointments Appointment[]
}

model Doctor {
  id             Int           @id @default(autoincrement())
  user_id        Int           @unique
  specialization String
  license_number String        @unique
  user           User          @relation(fields: [user_id], references: [id])
  appointments   Appointment[]
  schedules      Schedule[]
}

model Appointment {
  id                 Int                  @id @default(autoincrement())
  patient_id         Int
  doctor_id          Int
  date               DateTime             @db.Date
  time               DateTime             @db.Time(6)
  status             AppointmentStatus    @default(zarezerwowana)
  cancel_reason      String?
  doctor             Doctor               @relation(fields: [doctor_id], references: [id])
  patient            User                 @relation(fields: [patient_id], references: [id])
  appointmentDetails Appointment_details?
}

model Appointment_details {
  id              Int         @id @default(autoincrement())
  appointment_id  Int         @unique
  diagnosis       String
  recommendations String
  prescription    Boolean
  appointment     Appointment @relation(fields: [appointment_id], references: [id])
}

model Schedule {
  id              Int      @id @default(autoincrement())
  doctor_id       Int
  day_of_the_week Int
  hour_from       DateTime @db.Time(6)
  hour_to         DateTime @db.Time(6)
  doctor          Doctor   @relation(fields: [doctor_id], references: [id])
  @@unique([doctor_id, day_of_the_week])
}
